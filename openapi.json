{
  "swagger": "2.0",
  "info": {
    "title": "Rapid AI MCP Demo",
    "description": "MCP Server for Copilot Studio — provides customer/order tools and resources via Streamable HTTP transport. Also includes MCP prompts (supported by MCP Inspector and VS Code, not yet by Copilot Studio).",
    "version": "1.0.0"
  },
  "host": "https://dqwq2t86-3100.usw2.devtunnels.ms",
  "basePath": "/",
  "schemes": ["https"],
  "consumes": ["application/json"],
  "produces": ["application/json", "text/event-stream"],
  "paths": {
    "/mcp": {
      "post": {
        "x-ms-agentic-protocol": "mcp-streamable-1.0",
        "operationId": "McpStreamableTransport",
        "summary": "MCP Streamable HTTP endpoint",
        "description": "Handles MCP JSON-RPC requests via Streamable HTTP. Copilot Studio sends tool calls and resource reads through this endpoint.",
        "parameters": [
          {
            "in": "header",
            "name": "Accept",
            "type": "string",
            "required": true,
            "default": "application/json, text/event-stream",
            "description": "Must accept both JSON and SSE responses"
          },
          {
            "in": "header",
            "name": "Content-Type",
            "type": "string",
            "required": true,
            "default": "application/json",
            "description": "Request body is JSON-RPC"
          },
          {
            "in": "body",
            "name": "body",
            "description": "MCP JSON-RPC request payload",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "jsonrpc": { "type": "string", "example": "2.0" },
                "id": { "type": "integer", "example": 1 },
                "method": { "type": "string", "example": "initialize" },
                "params": { "type": "object" }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "MCP JSON-RPC response (may be SSE stream or JSON)"
          },
          "400": {
            "description": "Missing session ID on non-initialize request"
          },
          "404": {
            "description": "Session not found or expired"
          }
        }
      }
    }
  }
}
